{
  "ontology_meta": {
    "name": "Modern Human Life Ontology (MHLO)",
    "version": "1.0.0",
    "scope": "Comprehensive conceptual schema for contemporary human existence, circa 2020s",
    "last_updated": "2026-04-21",
    "principles": [
      "Multidimensionality",
      "Intersectionality",
      "Digital-physical hybridity",
      "Temporal dynamism",
      "Global-local nestedness"
    ]
  },
  "core_agent": {
    "entity_id": "human_agent",
    "description": "The central subject—a biological, psychological, social, and digital entity existing in time and space.",
    "universal_properties": [
      {
        "property": "unique_identifier",
        "type": "string",
        "scope": "global"
      },
      {
        "property": "birth_timestamp",
        "type": "ISO8601 datetime"
      },
      {
        "property": "biological_sex",
        "type": "enumeration",
        "values": [
          "female",
          "male",
          "intersex",
          "unknown"
        ]
      },
      {
        "property": "gender_identity",
        "type": "string_or_array",
        "note": "Self-determined; spectrum including non-binary, trans, cis, etc."
      },
      {
        "property": "temporal_phase",
        "type": "enumeration",
        "values": [
          "prenatal",
          "infancy",
          "childhood",
          "adolescence",
          "emerging_adulthood",
          "adulthood",
          "middle_age",
          "late_adulthood",
          "senescence",
          "end_of_life"
        ]
      },
      {
        "property": "neurotype",
        "type": "string",
        "examples": [
          "allistic",
          "autistic",
          "ADHD",
          "dyslexic",
          "non-specified"
        ],
        "note": "Recognizes neurodiversity paradigm"
      }
    ]
  },
